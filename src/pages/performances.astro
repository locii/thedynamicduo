---
import RenderedPage from "../components/RenderedPage.astro";
---

<RenderedPage slug="performances">
  <div class="mt-10 rounded-sm border border-ink-line bg-ink-soft p-8">
    <h3 class="font-[family-name:var(--font-serif)] text-2xl text-bone">Check your date</h3>
    <p class="mt-2 max-w-xl text-bone-dim">
      Send us your venue, date and the atmosphere you're after, and we'll confirm availability and options.
    </p>
    <a
      href="/contact"
      class="mt-5 inline-flex items-center gap-2 rounded-sm bg-brass px-7 py-3.5 text-sm font-medium tracking-wide text-ink transition hover:bg-brass-soft"
    >
      Enquire now
    </a>
  </div>
</RenderedPage>
