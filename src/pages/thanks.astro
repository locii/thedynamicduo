---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Thank you" description="Thanks for your enquiry — we'll be in touch soon.">
  <section class="mx-auto flex min-h-[70vh] max-w-3xl flex-col items-center justify-center px-6 py-32 text-center">
    <p class="eyebrow mb-5">Enquiry received</p>
    <h1 class="text-4xl text-bone sm:text-5xl">Thank you</h1>
    <p class="mt-6 max-w-xl text-lg text-bone-dim">
      Your message is on its way. We'll get back to you as soon as we can — usually within a couple of days.
    </p>
    <a
      href="/"
      class="mt-10 inline-flex items-center gap-2 rounded-sm border border-bone/25 px-7 py-3.5 text-sm tracking-wide text-bone transition hover:border-brass hover:text-brass"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
