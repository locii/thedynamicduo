---
import RenderedPage from "../components/RenderedPage.astro";

const cards = [
  {
    href: "/performances",
    title: "Weddings & Events",
    body: "Refined live guitar for ceremonies, receptions, corporate functions and private events across Melbourne.",
    cta: "See performances",
  },
  {
    href: "/lessons",
    title: "Guitar Lessons",
    body: "Classical and contemporary tuition with Conservatorium-trained guitarists — all ages and levels.",
    cta: "Explore lessons",
  },
];
---

<RenderedPage slug="welcome" heroSize="full">
  <div slot="hero-cta" class="mt-10 flex flex-wrap gap-4">
    <a
      href="/performances"
      class="inline-flex items-center gap-2 rounded-sm bg-brass px-7 py-3.5 text-sm font-medium tracking-wide text-ink transition hover:bg-brass-soft"
    >
      Book the duo
    </a>
    <a
      href="/lessons"
      class="inline-flex items-center gap-2 rounded-sm border border-bone/25 px-7 py-3.5 text-sm font-medium tracking-wide text-bone transition hover:border-brass hover:text-brass"
    >
      Guitar lessons
    </a>
  </div>

  <!-- Feature cards below the intro copy -->
  <section class="mt-8 grid gap-6 md:grid-cols-2">
    {
      cards.map((c) => (
        <a
          href={c.href}
          class="group flex flex-col justify-between rounded-sm border border-ink-line bg-ink-soft p-8 transition hover:border-brass/60"
        >
          <div>
            <h3 class="font-[family-name:var(--font-serif)] text-2xl text-bone">{c.title}</h3>
            <p class="mt-3 text-bone-dim">{c.body}</p>
          </div>
          <span class="mt-6 inline-flex items-center gap-2 text-sm text-brass transition group-hover:gap-3">
            {c.cta}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      ))
    }
  </section>
</RenderedPage>
