---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt?: string;
  position?: string;
  eyebrow?: string;
  title: string;
  subtitle?: string;
  /** Shorter hero for interior pages; full-height only really suits the home page. */
  size?: "full" | "tall" | "short";
}

const { image, alt = "", position = "center", eyebrow, title, subtitle, size = "tall" } = Astro.props;

const heights: Record<string, string> = {
  full: "min-h-[92vh]",
  tall: "min-h-[62vh] lg:min-h-[70vh]",
  short: "min-h-[46vh] lg:min-h-[52vh]",
};
---

<section class:list={["relative flex items-end overflow-hidden", heights[size]]}>
  <Image
    src={image}
    alt={alt}
    widths={[720, 1280, 1920, 2400]}
    sizes="100vw"
    class="absolute inset-0 h-full w-full object-cover"
    style={`object-position: ${position}`}
    loading="eager"
    fetchpriority="high"
  />
  <!-- Legibility scrim -->
  <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/55 to-ink/20"></div>
  <div class="absolute inset-0 bg-ink/25"></div>

  <div class="relative mx-auto w-full max-w-7xl px-6 pb-16 pt-32 lg:px-10 lg:pb-24">
    {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
    <h1 class="max-w-4xl text-4xl leading-[1.05] text-bone sm:text-5xl lg:text-6xl">
      {title}
    </h1>
    {
      subtitle && (
        <p class="mt-6 max-w-2xl text-lg text-bone-dim lg:text-xl">{subtitle}</p>
      )
    }
    <slot />
  </div>
</section>
