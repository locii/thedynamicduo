---
import { site, nav } from "../site";
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-line bg-ink-soft">
  <div class="mx-auto max-w-7xl px-6 py-14 lg:px-10">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between">
      <div class="max-w-sm">
        <p class="font-[family-name:var(--font-serif)] text-2xl text-bone">{site.name}</p>
        <p class="mt-1 text-xs uppercase tracking-[0.28em] text-brass">{site.tagline}</p>
        <p class="mt-4 text-sm text-bone-dim">
          Classical & contemporary guitar for weddings, corporate events and lessons — {site.location}.
        </p>
      </div>

      <nav class="grid grid-cols-2 gap-x-10 gap-y-2" aria-label="Footer">
        {
          nav.map((item) => (
            <a href={item.href} class="text-sm text-bone-dim transition-colors hover:text-brass">
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="text-sm">
        <p class="eyebrow mb-3">Get in touch</p>
        <a href={`mailto:${site.contactEmail}`} class="block text-bone-dim transition-colors hover:text-brass">
          {site.contactEmail}
        </a>
        {
          site.instagram && (
            <a
              href={site.instagram}
              class="mt-2 block text-bone-dim transition-colors hover:text-brass"
              target="_blank"
              rel="noopener"
            >
              {site.instagramHandle ?? "Instagram"}
            </a>
          )
        }
        <a href="/contact" class="mt-2 block text-bone-dim transition-colors hover:text-brass">
          Enquiry form
        </a>
      </div>
    </div>

    <div class="mt-12 border-t border-ink-line pt-6 text-xs text-bone-dim/70">
      &copy; {year} {site.name}. All rights reserved.
    </div>
  </div>
</footer>
